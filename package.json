{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:clean": "node scripts/dev-clean.mjs",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test:smoke": "tsx scripts/smoke-api.ts",
    "test:integration": "npm run test:smoke && npm run test:sprint4 && npm run test:sprint5 && npm run test:sprint6",
    "test:auth-checklist": "tsx scripts/test-auth-checklist.ts",
    "test:memberships-checkin": "tsx scripts/test-memberships-checkin.ts",
    "test:alerts": "tsx scripts/verify-alerts-panel.ts",
    "test:sprint1": "tsx scripts/test-sprint1.ts",
    "test:sprint2": "tsx scripts/test-sprint2.ts",
    "test:sprint3": "tsx scripts/test-sprint3.ts",
    "test:sprint4": "tsx scripts/test-sprint4.ts",
    "test:sprint5": "tsx scripts/test-sprint5.ts",
    "test:sprint6": "tsx scripts/test-sprint6.ts",
    "db:migrate": "tsx scripts/apply-migrations.ts",
    "db:create-admin": "tsx scripts/create-admin.ts",
    "db:migrate-from-sqlite": "tsx scripts/migrate-sqlite-to-pg.ts",
    "db:restore-demo": "tsx scripts/restore-demo-users.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/nodemailer": "^8.0.1",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.0.2",
    "nodemailer": "^9.0.0",
    "pg": "^8.16.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.15.4",
    "autoprefixer": "^10.4.21",
    "better-sqlite3": "^12.4.1",
    "esbuild": "^0.28.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
