# Copia este archivo a .env y completa los valores.

# Obligatorio — mínimo 32 caracteres, valor aleatorio (no uses ejemplos de documentación).
# Generar: openssl rand -base64 48
JWT_SECRET=

# Obligatorio — Supabase: Project Settings → Database → Connection string (pooler 6543)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Opcional
NODE_ENV=development
PORT=3000

# Check-in kiosk (misma clave en ambas; mín. 16 caracteres, aleatoria)
# Generar: openssl rand -base64 24
KIOSK_API_KEY=
VITE_KIOSK_KEY=

# Tasa Bs/USD para el formulario de pagos del miembro (opcional, default 40.5)
VITE_EXCHANGE_RATE=40.5

# Cuentas demo (solo CI / npm run db:restore-demo — no usar en flujo normal)
# DEMO_PASSWORD=

# Primer administrador (opcional — npm run db:create-admin)
# ADMIN_FULL_NAME=
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
# ALLOW_PUBLIC_REGISTER=true

# Importación única desde SQLite legacy
# SQLITE_PATH=./gym.db

# Supabase Storage — comprobantes de pago persistentes (recomendado)
# SUPABASE_URL se deduce de DATABASE_URL si no se define
# SUPABASE_URL=https://TU_PROJECT_REF.supabase.co
# Service role: Project Settings → API → service_role (NUNCA en el frontend)
# SUPABASE_SERVICE_ROLE_KEY=

# --- Alertas de vencimiento (opcional) ---

# Intervalo del cron en ms (default: 3600000 = 1 hora)
# EXPIRY_CRON_INTERVAL_MS=3600000

# Secreto para Cron Job externo (Render) — POST /api/settings/expiry/run
# Generar: openssl rand -base64 32
# CRON_SECRET=

# Retención automática de logs (cron diario del servidor)
# AUDIT_LOG_RETENTION_DAYS=90
# EXPIRY_NOTIF_LOG_RETENTION_DAYS=180

# Email SMTP — Gmail / Google Workspace (contraseña de aplicación, no la contraseña normal)
# Guía Render: docs/RENDER-NOTIFICACIONES.md
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tu@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# SMTP_FROM=Caribean Gym <tu@gmail.com>

# Emails de admin para resumen diario (separados por coma)
# ADMIN_NOTIFY_EMAILS=admin@gym.com

# SMS Twilio (opcional)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+1234567890

# Meta WhatsApp Cloud API — guía: docs/GUIA-WHATSAPP-META.md
# WHATSAPP_PROVIDER=meta
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_API_VERSION=v21.0

# Plantillas Meta (producción) — nombres aprobados en Meta Business Manager
# WHATSAPP_TEMPLATE_EXPIRING=membership_expiring
# WHATSAPP_TEMPLATE_EXPIRED=membership_expired
# WHATSAPP_TEMPLATE_GENERIC=caribean_gym_alert
# WHATSAPP_USE_TEMPLATES=true

# WhatsApp Twilio (alternativa — sandbox o número aprobado)
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
