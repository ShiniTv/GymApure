# Copia este archivo a .env y completa los valores.

# Obligatorio — mínimo 32 caracteres, valor aleatorio (no uses ejemplos de documentación).
# Generar: openssl rand -base64 48
JWT_SECRET=

# Desarrollo local — copia .env.dev.example → .env.dev (npm run db:create-dev-project)
# DATABASE_URL y SUPABASE_SERVICE_ROLE_KEY deben ser del proyecto DEV, no de Render.
DATABASE_URL=postgresql://postgres.[DEV_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
SUPABASE_SERVICE_ROLE_KEY=

# Producción (Render): credenciales en .env.prod — npm run db:migrate:prod
NODE_ENV=development
PORT=3000

# Check-in: solo personal autenticado (admin/recepcionista) vía /reception o /check-in

# Tasa BCV: se actualiza automáticamente en el servidor (cron + scraper bcv.org.ve).
# Override manual disponible en Configuración → Tasa de cambio USD.
# EXCHANGE_RATE_CRON_IN_DEV=true — activa cron de tasa en desarrollo local (opcional)

# ADMIN_NOTIFY_EMAILS=soporte.gymapure@gmail.com

# Cuentas demo (solo CI / npm run db:restore-demo — no usar en flujo normal)
# DEMO_PASSWORD=

# Primer administrador (opcional — npm run db:create-admin)
# ADMIN_FULL_NAME=
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
# ALLOW_PUBLIC_REGISTER=true

# Importación única desde SQLite legacy
# SQLITE_PATH=./gym.db

# Supabase Storage — comprobantes, avatares y videos
# OBLIGATORIO en producción (Render). Sin esto el servidor no arranca en NODE_ENV=production.
# SUPABASE_URL se deduce de DATABASE_URL si no se define
# SUPABASE_URL=https://TU_PROJECT_REF.supabase.co
# Service role: Project Settings → API → Legacy `service_role` (JWT eyJ…) o nueva Secret key (sb_secret_…)
# NUNCA en el frontend. Sin comillas. Si falla el upload, reinicia el servidor tras corregir.
# SUPABASE_SERVICE_ROLE_KEY=

# --- Producción (Render) ---
# CORS: orígenes permitidos separados por coma (solo si API y frontend están en hosts distintos).
# En despliegue monolítico same-origin en Render, puedes omitir CORS_ORIGINS.
# CORS_ORIGINS=https://caribean-gym.onrender.com,https://tudominio.com

# VITE_* se embeben en el build. En Render deben existir ANTES del deploy (clear build cache si cambias).
# VITE_SENTRY_DSN en sección Sentry.

# FFmpeg — compresión automática de videos de ejercicios al subir (opcional; usa PATH si no se define)
# Windows: choco install ffmpeg   |   macOS: brew install ffmpeg   |   Linux: apt install ffmpeg
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe

# --- Alertas de vencimiento (opcional) ---

# Opcional — logs del servidor (debug | info | warn | error). En dev el default es warn.
# LOG_LEVEL=info

# Cron de vencimientos en desarrollo (por defecto desactivado en dev)
# EXPIRY_CRON_IN_DEV=true
# EXPIRY_CRON_INTERVAL_MS=3600000

# Secreto para Cron Job externo (Render) — POST /api/settings/expiry/run y /api/exchange-rate/refresh
# Obligatorio en producción. Generar: openssl rand -base64 32
# CRON_SECRET=

# Rate limiting y bloqueo de login distribuido (opcional; recomendado multi-instancia en Render)
# REDIS_URL=redis://default:password@host:6379

# Rechazar contraseñas que aparecen en filtraciones conocidas (Have I Been Pwned)
# ENABLE_HIBP_CHECK=false

# URL pública HTTPS (obligatorio en producción — enlaces de recuperar contraseña)
# PUBLIC_APP_URL=https://caribean-gym.onrender.com

# Verificación TLS de PostgreSQL (opcional; ruta al CA de Supabase)
# DATABASE_SSL_CA=

# Solo desarrollo: imprimir enlaces de reset en consola
# DEV_LOG_RESET_LINKS=false

# Retención automática de logs (cron diario del servidor)
# AUDIT_LOG_RETENTION_DAYS=90
# EXPIRY_NOTIF_LOG_RETENTION_DAYS=180
# READ_NOTIFICATIONS_RETENTION_DAYS=90
# RESET_TOKEN_RETENTION_DAYS=7
# PUSH_SUBSCRIPTION_RETENTION_DAYS=90

# Consultas SQL más lentas que este umbral (ms) generan log + alerta Sentry
# SLOW_QUERY_MS=2000

# --- Sentry — Error tracking (opcional) ---
# SENTRY_DSN=https://xxxxx@sentry.io/123
# VITE_SENTRY_DSN=https://xxxxx@sentry.io/123
# Build-time source maps (CI/prod only):
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# --- Correo SMTP (Gmail + contraseña de aplicación) ---
# Obligatorio en producción para: bienvenida, recuperar contraseña, pagos.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=soporte.gymapure@gmail.com
# SMTP_PASS=
# SMTP_FROM=GymApure <soporte.gymapure@gmail.com>
# PUBLIC_APP_URL=https://caribean-gym.onrender.com

# --- Mailpit (tests locales / npm run mailpit:up) ---
# Captura SMTP en localhost:1025 — UI en http://localhost:8025
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_SECURE=false
# SMTP_USER=test
# SMTP_PASS=test
# SMTP_FROM=GymApure Test <test@gym.test>
# MAILPIT_API_URL=http://localhost:8025

# --- Notificaciones Push (opcional) ---
# Generar VAPID keys: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@caribeangym.com
