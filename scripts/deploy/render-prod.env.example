# Variables para Render Dashboard → caribean-gym → Environment
# Las no secretas también están en render.yaml (Blueprint Sync las aplica).
#
# Obligatorias (secretos — pegar en Dashboard o dejar sync: false):
# JWT_SECRET=<openssl rand -base64 48>
# DATABASE_URL=postgresql://...@...pooler.supabase.com:6543/postgres
# SUPABASE_SERVICE_ROLE_KEY=<service_role prod>
# CRON_SECRET=<openssl rand -base64 32>
#
# Aplicadas por Blueprint (no hace falta duplicar si hiciste Sync):
PUBLIC_APP_URL=https://caribean-gym.onrender.com
# REDIS_URL → inyectada desde servicio caribean-gym-kv (Key Value)
#
# SMTP (recomendado):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=soporte.gymapure@gmail.com
SMTP_PASS=<contraseña-de-aplicacion-sin-espacios>
SMTP_FROM=GymApure <soporte.gymapure@gmail.com>
VAPID_SUBJECT=mailto:soporte.gymapure@gmail.com
ADMIN_NOTIFY_EMAILS=soporte.gymapure@gmail.com
#
# Opcional:
# ENABLE_HIBP_CHECK=true
# CORS_ORIGINS=https://tudominio.com
