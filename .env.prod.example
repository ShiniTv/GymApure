# Operaciones de producción desde tu PC (npm run db:*:prod, deploy:preflight).
# Gym en vivo: GymApure – Producción (ref ffjwvlcwhyskddqqojnp) — mismo que Render.
# NO uses este archivo para desarrollo diario — usa .env.dev (GymApure – Desarrollo).
# Render Dashboard tiene sus propias variables; esto es solo para CLI local.
#
# Copia a .env.prod y completa los secretos desde Render → Environment
# o Supabase Dashboard → GymApure – Producción → Settings
#
# Bootstrap inicial: npm run env:init
# Tras rotar password BD: npm run env:configure-prod -- <password>

NODE_ENV=production
PORT=3000
PUBLIC_APP_URL=https://caribean-gym.onrender.com

# Obligatorios — pegar valores reales (nunca commitear .env.prod)
JWT_SECRET=CHANGEME_GENERATE_WITH_openssl_rand_base64_48
DATABASE_URL=postgresql://postgres.ffjwvlcwhyskddqqojnp:CHANGEME@aws-1-us-west-1.pooler.supabase.com:6543/postgres
SUPABASE_SERVICE_ROLE_KEY=CHANGEME_PROD_SERVICE_ROLE_KEY
CRON_SECRET=CHANGEME_GENERATE_WITH_openssl_rand_base64_32

# Recomendado en Render (Key Value / Redis)
# REDIS_URL=redis://...

# SMTP (recuperar contraseña, bienvenida, pagos)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=soporte.gymapure@gmail.com
SMTP_PASS=CHANGEME_APP_PASSWORD
SMTP_FROM=GymApure <soporte.gymapure@gmail.com>

# Opcional — análisis de comida por foto (Gemini Flash). Solo backend.
# GEMINI_API_KEY=CHANGEME
VAPID_SUBJECT=mailto:soporte.gymapure@gmail.com
ADMIN_NOTIFY_EMAILS=soporte.gymapure@gmail.com

# Recomendado en producción
# MFA opcional: el staff puede activarlo en /security. No forzar.
REQUIRE_MFA_FOR_STAFF=false
ENABLE_HIBP_CHECK=true
# CORS_ORIGINS=https://caribean-gym.onrender.com
