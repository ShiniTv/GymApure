# Staging — copia de producción SIN datos reales de miembros.
# Crear un tercer proyecto Supabase, copiar este archivo a .env.staging y completar.
# Bootstrap: npm run env:init-staging
#
# Uso: probar migraciones y deploy antes de prod.
# NUNCA apuntes staging a ffjwvlcwhyskddqqojnp (prod).
#
# Release gate: npm run deploy:release -- --run

STAGING_DB_PASSWORD=CHANGEME
DATABASE_URL=postgresql://postgres.CHANGEME_STAGING_REF:CHANGEME@aws-0-us-west-1.pooler.supabase.com:6543/postgres
SUPABASE_SERVICE_ROLE_KEY=CHANGEME_STAGING_SERVICE_ROLE_KEY

JWT_SECRET=CHANGEME_GENERATE_WITH_openssl_rand_base64_48
CRON_SECRET=CHANGEME_GENERATE_WITH_openssl_rand_base64_32
NODE_ENV=production
PORT=3000
PUBLIC_APP_URL=https://CHANGEME-staging.onrender.com

# Mismas políticas que prod
REQUIRE_MFA_FOR_STAFF=false
ENABLE_HIBP_CHECK=true

# TLS verificado (recomendado): ruta al CA o PEM completo
# DATABASE_SSL_CA=

# Observabilidad (opcional en staging)
# SENTRY_DSN=
# VITE_SENTRY_DSN=
# REDIS_URL=

# SMTP de prueba (no usar buzón de clientes reales)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=CHANGEME
SMTP_PASS=CHANGEME
SMTP_FROM=GymApure Staging <CHANGEME>
